{
  "dashboard": {
    "title": "RSV Gen 2 - Business Metrics",
    "tags": ["rsv-gen2", "business", "metrics"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Bookings Created (Today)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(increase(bookings_created_total[24h]))",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "orientation": "auto"
        }
      },
      {
        "id": 2,
        "title": "Active Bookings",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "bookings_active",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Tickets Created (Today)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(increase(tickets_created_total[24h]))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Open Tickets",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "tickets_open",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Bookings Created Over Time",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "rate(bookings_created_total[5m])",
            "legendFormat": "{{status}} {{payment_status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "short", "label": "Bookings/sec" },
          { "format": "short" }
        ]
      },
      {
        "id": 6,
        "title": "Tickets Created Over Time",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "rate(tickets_created_total[5m])",
            "legendFormat": "{{category}} {{priority}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "short", "label": "Tickets/sec" },
          { "format": "short" }
        ]
      },
      {
        "id": 7,
        "title": "Ticket Resolution Time",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(ticket_resolution_time_seconds_bucket[5m]))",
            "legendFormat": "p95 - {{category}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Resolution Time" },
          { "format": "short" }
        ]
      },
      {
        "id": 8,
        "title": "Tickets SLA Breached",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
        "targets": [
          {
            "expr": "tickets_sla_breached",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      {
        "id": 9,
        "title": "Check-ins Completed",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
        "targets": [
          {
            "expr": "sum(increase(checkins_completed_total[24h]))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "Check-in Duration",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(checkin_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "s", "label": "Duration" },
          { "format": "short" }
        ]
      },
      {
        "id": 11,
        "title": "Payments Processed",
        "type": "graph",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "targets": [
          {
            "expr": "rate(payments_processed_total[5m])",
            "legendFormat": "{{payment_method}} {{status}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          { "format": "short", "label": "Payments/sec" },
          { "format": "short" }
        ]
      }
    ],
    "time": {
      "from": "now-6h",
      "to": "now"
    }
  }
}

