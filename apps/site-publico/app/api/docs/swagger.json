{
  "openapi": "3.0.0",
  "info": {
    "title": "RSV Gen 2 API",
    "version": "2.0.0",
    "description": "API completa para gestão de reservas de hospedagem - RSV Gen 2",
    "contact": {
      "name": "RSV Support",
      "email": "support@rsv.com"
    }
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de desenvolvimento"
    },
    {
      "url": "https://api.rsv.com",
      "description": "Servidor de produção"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": false
          },
          "error": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "Success": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "example": true
          },
          "data": {
            "type": "object"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "responses": {
      "UnauthorizedError": {
        "description": "Token de autenticação inválido ou ausente",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "ForbiddenError": {
        "description": "Acesso negado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "ValidationError": {
        "description": "Dados de entrada inválidos",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      },
      "NotFoundError": {
        "description": "Recurso não encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/Error"
            }
          }
        }
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Autenticação",
      "description": "Endpoints de autenticação"
    },
    {
      "name": "Reservas",
      "description": "Gerenciamento de reservas"
    },
    {
      "name": "Viagens em Grupo",
      "description": "Wishlists, split payment, convites"
    },
    {
      "name": "Smart Pricing",
      "description": "Precificação inteligente com IA"
    },
    {
      "name": "Programa Top Host",
      "description": "Ratings, badges, leaderboard"
    },
    {
      "name": "Seguros",
      "description": "Apólices e sinistros"
    },
    {
      "name": "Verificação",
      "description": "Verificação de propriedades"
    },
    {
      "name": "Integrações",
      "description": "Google Calendar, Smart Locks, Klarna"
    }
  ],
  "paths": {
    "/api/auth/login": {
      "post": {
        "summary": "Login de usuário",
        "tags": [
          "Autenticação"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password"
                  }
                },
                "required": [
                  "email",
                  "password"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login bem-sucedido"
          },
          "401": {
            "description": "Credenciais inválidas"
          }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "summary": "Registro de novo usuário",
        "tags": [
          "Autenticação"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string",
                    "format": "password",
                    "minLength": 8
                  },
                  "name": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "password",
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuário criado"
          },
          "400": {
            "description": "Dados inválidos"
          }
        }
      }
    },
    "/api/bookings": {
      "get": {
        "summary": "Listar reservas",
        "tags": [
          "Reservas"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pending",
                "confirmed",
                "cancelled",
                "completed"
              ]
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de reservas"
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      },
      "post": {
        "summary": "Criar nova reserva",
        "tags": [
          "Reservas"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "property_id": {
                    "type": "integer"
                  },
                  "check_in": {
                    "type": "string",
                    "format": "date"
                  },
                  "check_out": {
                    "type": "string",
                    "format": "date"
                  },
                  "guests": {
                    "type": "integer",
                    "minimum": 1
                  }
                },
                "required": [
                  "property_id",
                  "check_in",
                  "check_out",
                  "guests"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reserva criada"
          },
          "400": {
            "description": "Dados inválidos"
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      }
    },
    "/api/wishlists": {
      "get": {
        "summary": "Listar wishlists do usuário",
        "tags": [
          "Viagens em Grupo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de wishlists"
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      },
      "post": {
        "summary": "Criar wishlist compartilhada",
        "tags": [
          "Viagens em Grupo"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "member_emails": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "email"
                    }
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Wishlist criada"
          },
          "400": {
            "description": "Dados inválidos"
          }
        }
      }
    },
    "/api/pricing/smart": {
      "post": {
        "summary": "Calcular preço inteligente",
        "tags": [
          "Smart Pricing"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "item_id": {
                    "type": "integer"
                  },
                  "base_price": {
                    "type": "number",
                    "minimum": 0
                  },
                  "check_in": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "check_out": {
                    "type": "string",
                    "format": "date-time"
                  },
                  "location": {
                    "type": "string"
                  }
                },
                "required": [
                  "item_id",
                  "base_price",
                  "check_in",
                  "check_out"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preço calculado"
          },
          "400": {
            "description": "Dados inválidos"
          }
        }
      }
    },
    "/api/quality/leaderboard": {
      "get": {
        "summary": "Ranking de Top Hosts",
        "tags": [
          "Programa Top Host"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "min_bookings",
            "in": "query",
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Ranking de hosts"
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      }
    },
    "/api/insurance/policies": {
      "get": {
        "summary": "Listar apólices de seguro",
        "tags": [
          "Seguros"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de apólices"
          },
          "401": {
            "description": "Não autenticado"
          }
        }
      },
      "post": {
        "summary": "Criar apólice de seguro",
        "tags": [
          "Seguros"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "booking_id": {
                    "type": "integer"
                  },
                  "coverage_type": {
                    "type": "string",
                    "enum": [
                      "basic",
                      "standard",
                      "premium",
                      "comprehensive"
                    ]
                  },
                  "coverage_amount": {
                    "type": "number",
                    "minimum": 0
                  }
                },
                "required": [
                  "booking_id",
                  "coverage_type",
                  "coverage_amount"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Apólice criada"
          },
          "400": {
            "description": "Dados inválidos"
          }
        }
      }
    },
    "/api/verification/request": {
      "post": {
        "summary": "Solicitar verificação de propriedade",
        "tags": [
          "Verificação"
        ],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "property_id": {
                    "type": "integer"
                  },
                  "photos": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "video": {
                    "type": "string",
                    "format": "binary"
                  }
                },
                "required": [
                  "property_id",
                  "photos"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Solicitação criada"
          },
          "400": {
            "description": "Dados inválidos"
          }
        }
      }
    }
  }
}