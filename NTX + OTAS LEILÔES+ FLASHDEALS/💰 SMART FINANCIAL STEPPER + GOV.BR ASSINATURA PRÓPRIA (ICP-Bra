import { supabaseAdmin } from './supabase'
import * as pdfLib from 'pdf-lib'
import * as fs from 'fs/promises'
import * as path from 'path'

const ICP_A1_PATH = path.join(process.cwd(), 'certs', 'icpbrasil_a1.p12')
const ICP_A1_PASSWORD = process.env.ICPBRASIL_PASSWORD!

export async function generateAndSignContract(bookingData: any) {
  // 1. Gerar PDF do contrato
  const pdfDoc = await pdfLib.PDFDocument.create()
  const page = pdfDoc.addPage([595, 842]) // A4
  page.drawText(`Contrato RSV360 #${bookingData.id}`, { x: 50, y: 800, size: 20 })
  page.drawText(`Imóvel: ${bookingData.property_title}`, { x: 50, y: 750, size: 12 })
  page.drawText(`Período: ${bookingData.checkin} a ${bookingData.checkout}`, { x: 50, y: 730, size: 12 })
  page.drawText(`Valor Total: R$ ${bookingData.total_price.toLocaleString('pt-BR')}`, { x: 50, y: 710, size: 12 })
  
  const pdfBytes = await pdfDoc.save()

  // 2. Assinar com ICP-Brasil A1
  const signedPdfBytes = await signPDFWithICP(pdfBytes, ICP_A1_PATH, ICP_A1_PASSWORD)

  // 3. Salvar no Supabase Storage
  const fileName = `contracts/${bookingData.id}.pdf`
  const { data } = await supabaseAdmin.storage
    .from('contracts')
    .upload(fileName, Buffer.from(signedPdfBytes), {
      contentType: 'application/pdf',
      upsert: true
    })

  // 4. Atualizar booking
  await supabaseAdmin
    .from('bookings')
    .update({
      contract_signed_pdf_url: `https://your-supabase.co/storage/v1/object/public/contracts/${fileName}`,
      signature_status: 'signed',
      signature_provider: 'icpbrasil'
    })
    .eq('id', bookingData.id)

  return data.path
}

