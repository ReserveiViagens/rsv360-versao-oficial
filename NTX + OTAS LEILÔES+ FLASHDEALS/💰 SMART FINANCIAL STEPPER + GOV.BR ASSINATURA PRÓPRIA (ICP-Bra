export default function FinancialStepper({ propertyPrice, onConfirm }: StepperProps) {
  const [step, setStep] = useState(0)
  const [formData, setFormData] = useState({
    downPayment: 0,
    nights: 30,
    guests: 2,
    income: 0
  })

  const total = propertyPrice * formData.nights
  const monthlyPayment = calculateMonthly(total - formData.downPayment, formData.income)

  const steps = [
    { title: 'Entrada', icon: DollarSign, subtitle: 'Quanto pode dar de entrada?' },
    { title: 'Período', icon: Calendar, subtitle: 'Quantas noites?' },
    { title: 'Hóspedes', icon: Users, subtitle: 'Quantas pessoas?' },
    { title: 'Renda', icon: Percent, subtitle: 'Renda familiar mensal' },
    { title: 'Confirmação', icon: CheckCircle, subtitle: 'Revise e assine' }
  ]

  return (
    <div className="bg-white/80 backdrop-blur-xl rounded-3xl p-8 shadow-2xl border border-neutral-200 max-w-md mx-auto">
      <div className="flex items-center justify-between mb-8">
        <div className="flex items-center gap-3">
          <div className="w-12 h-12 bg-gradient-to-r from-emerald-500 to-blue-600 rounded-2xl flex items-center justify-center">
            <DollarSign className="w-6 h-6 text-white" />
          </div>
          <div>
            <h3 className="font-bold text-xl">Simulador Financeiro</h3>
            <p className="text-neutral-600 text-sm">Pré-aprovação em 60s</p>
          </div>
        </div>
        <div className="text-right">
          <p className="text-3xl font-black text-emerald-600">
            R$ {monthlyPayment.toLocaleString('pt-BR')}
          </p>
          <p className="text-xs text-neutral-500">/mês</p>
        </div>
      </div>

      {/* Progress Bar */}
      <div className="w-full bg-neutral-200 rounded-full h-2 mb-8">
        <div 
          className="bg-gradient-to-r from-emerald-500 to-blue-600 h-2 rounded-full transition-all duration-500"
          style={{ width: `${((step + 1) / steps.length) * 100}%` }}
        />
      </div>

      {/* Current Step */}
      <AnimatePresence mode="wait">
        <motion.div
          key={step}
          initial={{ x: 20, opacity: 0 }}
          animate={{ x: 0, opacity: 1 }}
          exit={{ x: -20, opacity: 0 }}
          className="space-y-6 mb-8"
        >
          <div className="flex items-center gap-4">
            <div className="w-12 h-12 bg-gradient-to-r from-neutral-100 to-neutral-200 rounded-2xl flex items-center justify-center">
              {steps[step].icon}
            </div>
            <div>
              <h4 className="font-bold text-lg">{steps[step].title}</h4>
              <p className="text-neutral-600 text-sm">{steps[step].subtitle}</p>
            </div>
          </div>

          {step === 0 && (
            <input
              type="range"
              min="0"
              max={total * 0.5}
              step="1000"
              value={formData.downPayment}
              onChange={(e) => setFormData({ ...formData, downPayment: Number(e.target.value) })}
              className="w-full h-2 bg-neutral-200 rounded-lg appearance-none cursor-pointer accent-emerald-500"
            />
          )}
          
          {/* ... outros steps similares */}
        </motion.div>
      </AnimatePresence>

      {/* Navigation */}
      <div className="flex gap-4 pt-8 border-t border-neutral-200">
        {step > 0 && (
          <motion.button
            whileHover={{ scale: 1.02 }}
            whileTap={{ scale: 0.98 }}
            onClick={() => setStep(step - 1)}
            className="flex-1 py-3 px-6 border border-neutral-300 rounded-2xl text-neutral-700 font-semibold hover:bg-neutral-50 transition-all"
          >
            Anterior
          </motion.button>
        )}
        
        <motion.button
          whileHover={{ scale: 1.02 }}
          whileTap={{ scale: 0.98 }}
          onClick={() => step < steps.length - 1 ? setStep(step + 1) : onConfirm(formData)}
          className={`flex-1 py-3 px-6 rounded-2xl font-semibold text-white transition-all ${
            step < steps.length - 1 
              ? 'bg-emerald-600 hover:bg-emerald-700' 
              : 'bg-gradient-to-r from-emerald-600 to-blue-600 hover:shadow-2xl shadow-emerald-500/25'
          }`}
        >
          {step < steps.length - 1 ? 'Próximo' : 'Gerar Contrato'}
        </motion.button>
      </div>
    </div>
  )
}

function calculateMonthly(amount: number, income: number): number {
  // Simulação Open Banking
  return Math.round((amount * 0.85) / 360 / 30) // 30 anos, 85% renda
}
