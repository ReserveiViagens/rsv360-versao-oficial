SELECT 
  rsv.total, 
  erp.valor_recebido,
  CASE 
    WHEN ABS(rsv.total - erp.valor_recebido) > 0.01 THEN 'CONFLITO'
    ELSE 'OK'
  END as status
FROM rsv360_payments rsv
FULL OUTER JOIN erp_receitas erp ON rsv.pix_id = erp.pix_id
WHERE date = CURRENT_DATE - 1;
