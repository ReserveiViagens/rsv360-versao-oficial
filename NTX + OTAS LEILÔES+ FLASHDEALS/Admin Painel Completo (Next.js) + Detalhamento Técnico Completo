sql
CREATE TABLE financial_audit (
  id UUID PRIMARY KEY,
  table_name TEXT,
  record_id UUID,
  operation TEXT,
  old_values JSONB,
  new_values JSONB,
  user_id UUID,
  ip_address INET,
  user_agent TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW()
);
