ROW LEVEL SECURITY (Postgres)

sql
ALTER TABLE financial_metrics ENABLE ROW LEVEL SECURITY;
CREATE POLICY tenant_isolation ON financial_metrics 
USING (tenant_id = current_setting('app.current_tenant')::uuid);
