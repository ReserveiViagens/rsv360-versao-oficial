# LLM Provider: ollama | openai | anthropic
LLM_PROVIDER=ollama

# Ollama (custo zero - local)
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (GPT-4o-mini barato)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude Haiku barato)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# API do trigger (porta do servidor Python)
TRIGGER_API_PORT=5050

# Caminho dos logs do backend RSV360
BACKEND_LOGS_PATH=../backend/logs
BACKEND_LOG_FILE=combined.log

# Pastas adicionais para o Coletor SRE (separadas por virgula)
# COLLECTOR_LOG_PATHS=backend/logs,apps/turismo/logs,apps/site-publico/logs
