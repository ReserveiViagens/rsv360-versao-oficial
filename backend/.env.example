# Configuracao do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rsv360
DB_USER=postgres
DB_PASSWORD=postgres

# Ambiente
NODE_ENV=development

# Logs em arquivo (para visualizar no Dashboard SRE - localhost:5050)
# LOG_TO_FILE=true

# Porta do Servidor
PORT=5000

# JWT Secret (gerar um valor aleatorio em producao)
JWT_SECRET=seu_jwt_secret_aqui

# Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha
